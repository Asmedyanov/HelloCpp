{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                    "/Zi",
                    "/EHsc",
                    "/nologo",
                    "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                    "/IC:\\vcpkg\\installed\\x64-windows\\include",
                    "${file}",
                    "/link",
                    "/LIBPATH:C:\\vcpkg\\installed\\x64-windows\\lib",
                    "hdf5_cpp.lib",
                    "hdf5.lib",
                    "DataFrame.lib"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}